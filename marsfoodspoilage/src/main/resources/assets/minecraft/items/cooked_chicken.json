{
  "model": {
    "type": "minecraft:select",
    "property": "marsfoodspoilage:freshness_state",
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/cooked_chicken"
    },
    "cases": [
      {
        "when": "stale",
        "model": {
          "type": "minecraft:model",
          "model": "marsfoodspoilage:item/cooked_chicken_stale"
        }
      },
      {
        "when": "spoiled",
        "model": {
          "type": "minecraft:model",
          "model": "marsfoodspoilage:item/cooked_chicken_spoiled"
        }
      }
    ]
  }
}
